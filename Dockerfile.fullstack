FROM node:20-alpine AS base

WORKDIR /app

RUN apk add --no-cache wget openssl libc6-compat

# Install dependencies first for better cache usage
COPY package.json package-lock.json* ./
RUN npm ci

# Copy source and build app (default Next output — use `next start`, not standalone server.js)
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
RUN npx prisma generate
RUN npm run build

EXPOSE 3003

CMD ["npm", "run", "start"]
