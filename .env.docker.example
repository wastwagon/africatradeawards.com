# Optional: copy to `.env` in the project root for `docker compose -f docker-compose.dev.yml` variable substitution.
# Compose loads `.env` automatically from the project root. For **host** `npm run dev` + Docker DB/Redis only, start from `.env.example` instead.

POSTGRES_DB=africa_trade_awards
POSTGRES_USER=africa_trade_user
POSTGRES_PASSWORD=devlocal_postgres
POSTGRES_PUBLISH_PORT=5433
REDIS_PUBLISH_PORT=6380
WEB_PUBLISH_PORT=3003

# Bump this when compiled theme CSS (sass → public/assets/css/main.css) looks cached in the browser
NEXT_PUBLIC_CSS_BUST=20260406

PUBLIC_BASE_URL=http://localhost:3003
AUTH_JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
BOOTSTRAP_ADMIN_SECRET=replace-bootstrap-secret
VOTE_IP_SALT=replace-salt
VOTE_CODE_SALT=replace-salt
EVENT_RECOVERY_CODE_SALT=replace-event-recovery-salt
EVENT_QR_SECRET=replace-event-qr-secret
EVENT_BADGE_SECRET=replace-event-badge-secret
VOTE_TOKEN_SECRET=replace-32-char-secret
VOTE_FP_SALT=replace-salt

VOTING_REQUIRE_EMAIL_VERIFICATION=false
VOTING_REQUIRE_CHALLENGE=false
LOGIN_RATE_LIMIT_ENABLED=false
LOGIN_MAX_PER_IP=1000
LOGIN_MAX_PER_ACCOUNT_AND_IP=1000
LOGIN_WINDOW_SECONDS=60

# SMTP optional for email flows locally
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
