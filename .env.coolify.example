# Copy to .env in Coolify service variables

POSTGRES_DB=africa_trade_awards
POSTGRES_USER=africa_trade_user
POSTGRES_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://africa_trade_user:replace_with_strong_password@postgres:5432/africa_trade_awards
REDIS_URL=redis://redis:6379
AUTH_JWT_SECRET=replace_with_very_long_random_secret
BOOTSTRAP_ADMIN_SECRET=replace_with_bootstrap_secret
VOTE_IP_SALT=replace_with_vote_ip_salt
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=no-reply@yourdomain.com
VOTING_REQUIRE_EMAIL_VERIFICATION=true
# Must remain false or unset in production (exposes codes/links in API when true without SMTP).
VOTING_DEV_EMAIL_BYPASS=false
VOTE_CODE_SALT=replace_with_vote_code_salt
EVENT_RECOVERY_CODE_SALT=replace_with_event_recovery_salt
EVENT_QR_SECRET=replace_with_event_qr_secret
EVENT_BADGE_SECRET=replace_with_event_badge_secret
VOTE_TOKEN_SECRET=replace_with_vote_token_secret
VOTE_FP_SALT=replace_with_vote_fp_salt
VOTING_REQUIRE_CHALLENGE=true
PUBLIC_BASE_URL=https://awards.yourdomain.com
# Auto-quarantine thresholds (valid votes only, before this submission)
VOTE_QUARANTINE_CROSS_ENTRY_IP_THRESHOLD=8
VOTE_QUARANTINE_FP_THRESHOLD=2
