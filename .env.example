# Africa Trade Awards — example environment for LOCAL development
# Copy to `.env` (never commit `.env`). For Docker Compose variable substitution, see `.env.docker.example`.

# --- Run Next on the HOST (`npm run dev`) while Postgres + Redis run via docker-compose.dev.yml ---
# Default published ports: Postgres 5433, Redis 6380 (see docker-compose.dev.yml).
DATABASE_URL="postgresql://africa_trade_user:devlocal_postgres@127.0.0.1:5433/africa_trade_awards"
REDIS_URL="redis://127.0.0.1:6380"

PUBLIC_BASE_URL=http://localhost:3003
NEXT_PUBLIC_SITE_URL=http://localhost:3003
NEXT_PUBLIC_CSS_BUST=20260406

# Auth & voting salts (use long random values; dev placeholders are fine locally only)
AUTH_JWT_SECRET=dev-only-change-me-use-32chars-minimum!!
BOOTSTRAP_ADMIN_SECRET=dev-bootstrap-secret
VOTE_IP_SALT=dev-vote-ip-salt
VOTE_CODE_SALT=dev-vote-code-salt
VOTE_TOKEN_SECRET=dev-vote-token-secret-32chars-min!
VOTE_FP_SALT=dev-vote-fp-salt
EVENT_RECOVERY_CODE_SALT=dev-event-recovery-salt
EVENT_QR_SECRET=dev-event-qr-secret
EVENT_BADGE_SECRET=dev-event-badge-secret

# Optional: relax voting for local testing
VOTING_REQUIRE_EMAIL_VERIFICATION=false
VOTING_REQUIRE_CHALLENGE=false
LOGIN_RATE_LIMIT_ENABLED=false

# SMTP (optional locally; required for contact form / mail flows in real envs)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
