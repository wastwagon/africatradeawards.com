# Dev image: dependencies only — source code comes from bind mount for hot reload.
FROM node:20-alpine

RUN apk add --no-cache libc6-compat openssl

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

EXPOSE 3003

# Default CMD overridden by docker-compose.dev.yml
CMD ["npm", "run", "dev:docker"]
