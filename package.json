{
  "name": "africa-trade-awards",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "npm run sass:build && next dev -p 3003",
    "compose:dev": "docker compose -f docker-compose.dev.yml up --build",
    "compose:dev:detach": "docker compose -f docker-compose.dev.yml up --build -d",
    "compose:dev:clean": "rm -rf .next && docker compose -f docker-compose.dev.yml restart web",
    "clean:next": "node scripts/rm-next.mjs",
    "build": "npm run clean:next && npm run sass:build && next build",
    "export": "npm run clean:next && npm run sass:build && next build",
    "start": "next start -p 3003",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prisma:seed:sync-canonical": "node scripts/prisma-seed-sync-canonical.mjs",
    "prisma:seed:demo": "node scripts/seed-demo.mjs",
    "worker:broadcast": "node scripts/broadcast-worker.js",
    "test:e2e": "node scripts/reset-e2e-rate-limits.mjs && playwright test",
    "test:e2e:headed": "node scripts/reset-e2e-rate-limits.mjs && playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "ops:verify": "node scripts/verify-onsite-ops.mjs",
    "smoke:http": "node scripts/smoke-critical-http.mjs",
    "sass": "sass --watch public/assets/scss/main.scss:public/assets/css/main.css",
    "sass:build": "sass public/assets/scss/main.scss:public/assets/css/main.css",
    "copy-elsewedy": "node scripts/copy-elsewedy-image.js",
    "serve:check": "./scripts/serve-and-check.sh 3080"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "aos": "^2.3.4",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.23",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "next": "14.2.35",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-modal-video": "^2.0.2",
    "sass": "^1.81.0",
    "sharp": "^0.34.5",
    "swiper": "^12.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/aos": "^3.0.7",
    "@types/archiver": "^7.0.0",
    "@types/node": "22.19.17",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18",
    "@types/react-modal-video": "^1.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "typescript": "^5"
  }
}
